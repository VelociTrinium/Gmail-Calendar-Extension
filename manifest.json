{
    "manifest_version": 3,
    "name": "Gmail Sorter + Smart Calendar",
    "version": "2.0",
    "description": "Categorizes Gmail emails with color-coded highlights and detects time-sensitive events for Google Calendar.",
    "permissions": ["activeTab", "scripting", "storage"],
    "host_permissions": [
        "https://mail.google.com/*",
        "http://localhost:8000/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
