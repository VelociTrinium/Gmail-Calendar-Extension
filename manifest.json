{
    "manifest_version": 3,
    "name": "Gmail Sorter + Smart Calendar",
    "version": "3.0",
    "description": "Categorizes Gmail emails and detects time-sensitive events for Google Calendar using Gmail thread IDs.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://mail.google.com/*",
        "http://localhost:8000/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
